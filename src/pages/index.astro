---
// ==========================================
// CHẶNG 1: LẤY VÀ XỬ LÝ DỮ LIỆU GOOGLE SHEETS DẠNG VỊ TRÍ CỘT
// ==========================================
const SHEET_ID = '10MHvD3yDWQVuR0oXnef9e_mo0G4U2DFfy8caKrezQ0o';
// Sử dụng URL quét toàn bộ bảng dữ liệu mặc định của tab đầu tiên
const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json`;

let products = [];

try {
  const response = await fetch(url);
  const text = await response.text();
  
  // Cắt bỏ phần chuỗi bọc ngoài của Google để lấy JSON thuần túy
  const jsonString = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
  const data = JSON.parse(jsonString);
  
  const rows = data.table.rows;
  
  if (rows && rows.length > 0) {
    products = rows.map(row => {
      // Hàm an toàn để lấy giá trị từ một ô (cell) dựa trên chỉ mục vị trí
      const getCellValue = (index) => {
        if (row.c && row.c[index]) {
          const cell = row.c[index];
          // Nếu có chuỗi định dạng .f (như ngày tháng) thì lấy .f, nếu không có thì lấy giá trị gốc .v
          return cell.f ? cell.f : (cell.v !== null ? String(cell.v) : '');
        }
        return '';
      };

      // Ánh xạ chuẩn xác tuyệt đối theo vị trí các cột từ A đến L trên Google Sheets của bạn
      return {
        id: getCellValue(0),                  // Cột A: id (Số quyết định)
        date: getCellValue(1),                // Cột B: date (Ngày ban hành)
        name: getCellValue(2),                // Cột C: name (Tên thương mại)
        declaredName: getCellValue(3),        // Cột D: declaredName (Tên khai báo)
        importer: getCellValue(4),            // Cột E: importer (Doanh nghiệp XNK)
        hsCode: getCellValue(5),              // Cột F: hsCode (Mã HS)
        authority: getCellValue(6),           // Cột G: authority (Cơ quan ban hành)
        category: getCellValue(7),            // Cột H: category (Phân loại danh mục)
        declarationNum: getCellValue(8),      // Cột I: declarationNum (Số tờ khai)
        sampleDesc: getCellValue(9),          // Cột J: sampleDesc (Mô tả mẫu)
        chemicalComposition: getCellValue(10), // Cột K: chemicalComposition (Thành phần hóa học)
        hsDescription: getCellValue(11)       // Cột L: hsDescription (Mô tả HS)
      };
    });

    // Bỏ qua hàng số 1 đầu tiên (Vì hàng số 1 chứa tiêu đề cột: id, date, name...)
    products = products.slice(1);
  }
} catch (error) {
  console.error("Lỗi hệ thống khi tải dữ liệu từ Google Sheets: ", error);
}
---

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Tra Cứu Phân Tích Phân Loại Hàng Hóa</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        header {
            text-align: center;
            margin-bottom: 40px;
        }
        header h1 {
            color: #0B2545;
            margin-bottom: 10px;
        }
        header p {
            color: #666;
            font-size: 1.1rem;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-top: 4px solid #134074;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 1px dashed #ddd;
            padding-bottom: 10px;
        }
        .doc-id {
            background-color: #EEF4F8;
            color: #134074;
            font-weight: bold;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.9rem;
        }
        .doc-date {
            color: #888;
            font-size: 0.85rem;
        }
        .product-name {
            font-size: 1.2rem;
            color: #0B2545;
            margin: 0 0 10px 0;
            font-weight: 600;
            line-height: 1.4;
        }
        .badge-container {
            margin-bottom: 15px;
        }
        .badge-hscode {
            background-color: #EEF1E6;
            color: #588157;
            font-weight: bold;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            border: 1px solid #A3B18A;
        }
        .badge-category {
            background-color: #FDF0D5;
            color: #C1121F;
            font-weight: bold;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            margin-left: 5px;
        }
        .details {
            font-size: 0.9rem;
            color: #555;
            background-color: #fafafa;
            padding: 10px;
            border-radius: 6px;
        }
        .details p {
            margin: 5px 0;
        }
        .label {
            font-weight: bold;
            color: #666;
        }
        .no-data {
            text-align: center;
            grid-column: 1 / -1;
            padding: 40px;
            color: #888;
            background: #fff;
            border-radius: 8px;
            border: 1px dashed #ccc;
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>Hệ Thống Tra Cứu Kết Quả Phân Tích Phân Loại</h1>
            <p>Dữ liệu được cập nhật tự động theo thời gian thực từ Google Sheets</p>
        </header>

        <div class="grid">
            {products.length > 0 ? (
                products.map((product) => (
                    // Chỉ hiển thị các dòng thực sự có chứa ID (Số quyết định) tránh hiển thị các hàng trống dưới bảng tính
                    product.id && (
                        <div class="card">
                            <div>
                                <div class="card-header">
                                    <span class="doc-id">{product.id}</span>
                                    <span class="doc-date">Ngày: {product.date || 'N/A'}</span>
                                </div>

                                <h3 class="product-name">{product.name || 'Chưa rõ tên hàng hóa'}</h3>

                                <div class="badge-container">
                                    <span class="badge-hscode">Mã HS: {product.hsCode || 'N/A'}</span>
                                    {product.category && <span class="badge-category">{product.category}</span>}
                                </div>

                                <div class="details">
                                    {product.declaredName && <p><span class="label">Tên khai báo:</span> {product.declaredName}</p>}
                                    {product.importer && <p><span class="label">Doanh nghiệp XNK:</span> {product.importer}</p>}
                                    {product.declarationNum && <p><span class="label">Số tờ khai:</span> {product.declarationNum}</p>}
                                    {product.authority && <p><span class="label">Cơ quan ban hành:</span> {product.authority}</p>}
                                    {product.sampleDesc && <p><span class="label">Mô tả mẫu:</span> {product.sampleDesc}</p>}
                                    {product.chemicalComposition && <p><span class="label">Thành phần hóa học:</span> {product.chemicalComposition}</p>}
                                    {product.hsDescription && <p><span class="label">Mô tả HS:</span> {product.hsDescription}</p>}
                                </div>
                            </div>
                        </div>
                    )
                ))
            ) : (
                <div class="no-data">
                    <p>Không tìm thấy dữ liệu hoặc đang đồng bộ từ Google Sheets...</p>
                </div>
            )}
        </div>
    </div>

</body>
</html>