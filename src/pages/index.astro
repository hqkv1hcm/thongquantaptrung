---
// src/pages/index.astro
---
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cổng Tra Cứu Phân Tích Phân Loại - Tổng Cục Hải Quan</title>
    
    <!-- Tailwind CSS CDN -->
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <!-- Alpine.js -->
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        customs: {
                            50: '#f8fafc',
                            100: '#f1f5f9',
                            500: '#1e40af',
                            600: '#1d4ed8',
                            700: '#0f172a',
                            amber: '#b45309'
                        }
                    }
                }
            }
        }
    </script>

    <style is:global>
        body {
            background-color: #f8fafc;
        }
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }

        @media print {
            body * {
                visibility: hidden !important;
            }
            #printable-area, #printable-area * {
                visibility: visible !important;
            }
            #printable-area {
                position: absolute !important;
                left: 0 !important;
                top: 0 !important;
                width: 100% !important;
                background: white !important;
                color: black !important;
                box-shadow: none !important;
                border: none !important;
                padding: 0 !important;
                margin: 0 !important;
            }
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body class="text-slate-800 flex flex-col min-h-screen antialiased font-sans" x-data="customsApp()">

    <!-- HEADER -->
    <header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm no-print">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center space-x-3 cursor-pointer" @click="resetFilters()">
                    <div class="bg-blue-600 p-2.5 rounded-xl flex items-center justify-center shadow-md shadow-blue-500/10">
                        <svg class="w-5.5 h-5.5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                    </div>
                    <div>
                        <div class="flex items-center space-x-1.5">
                            <span class="text-[9px] tracking-wider text-blue-600 font-extrabold uppercase">TỔNG CỤC HẢI QUAN VIỆT NAM</span>
                        </div>
                        <h1 class="text-xs sm:text-sm font-bold tracking-tight text-slate-900 uppercase">Cổng Tra Cứu Kết Quả Phân Tích Phân Loại</h1>
                    </div>
                </div>

                <div class="flex items-center space-x-3">
                    <span class="bg-emerald-50 text-emerald-700 border border-emerald-100 px-3 py-1 rounded-full text-xs font-semibold flex items-center space-x-1.5">
                        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                        <span class="hidden sm:inline">CSDL Mô phỏng gốc (2026)</span>
                        <span class="sm:hidden">Trực tuyến</span>
                    </span>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="flex-grow max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6 flex flex-col space-y-5 no-print">
        <!-- BỘ LỌC NÂNG CAO -->
        <div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-4">
                <div class="lg:col-span-5">
                    <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider block mb-1.5">Từ khóa tìm kiếm</label>
                    <div class="relative">
                        <input type="text" x-model="searchQuery" placeholder="Mã quyết định, tên mẫu, đặc tính kỹ thuật..." 
                               class="w-full text-sm pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-600 transition-all placeholder:text-slate-400">
                        <i class="fa-solid fa-magnifying-glass absolute left-3 top-3.5 text-slate-400 text-xs"></i>
                    </div>
                </div>

                <div class="lg:col-span-4">
                    <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider block mb-1.5">Mã số HS (2 - 8 Số)</label>
                    <div class="relative">
                        <input type="text" x-model="searchHs" placeholder="Ví dụ: 3824, 3902, 8517..." 
                               class="w-full text-sm pl-9 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl text-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-600 transition-all placeholder:text-slate-400 font-mono">
                        <i class="fa-solid fa-barcode absolute left-3 top-3.5 text-slate-400 text-xs"></i>
                    </div>
                </div>

                <div class="lg:col-span-3">
                    <label class="text-[11px] font-bold text-slate-500 uppercase tracking-wider block mb-1.5">Năm ban hành</label>
                    <select x-model="filterYear" class="w-full text-sm bg-slate-50 border border-slate-200 rounded-xl py-2 px-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-600 transition-all">
                        <option value="">Tất cả năm</option>
                        <option value="2026">Năm 2026</option>
                        <option value="2025">Năm 2025</option>
                        <option value="2024">Năm 2024</option>
                    </select>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3 pt-4 border-t border-slate-100">
                <div class="flex flex-wrap gap-1.5 items-center">
                    <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider mr-2">Phân loại mẫu:</span>
                    <template x-for="cat in categories" :key="cat">
                        <button @click="toggleCategory(cat)" 
                                :class="activeCategory === cat ? 'bg-blue-600 text-white font-semibold shadow-sm border-blue-600' : 'bg-slate-50 text-slate-600 hover:bg-slate-100 border-slate-200'"
                                class="text-xs px-3.5 py-1.5 rounded-full border transition-all duration-150"
                                x-text="cat">
                        </button>
                    </template>
                </div>

                <div class="flex flex-wrap items-center gap-4 w-full sm:w-auto justify-between sm:justify-end">
                    <label class="inline-flex items-center space-x-2 cursor-pointer text-xs text-slate-600">
                        <input type="checkbox" x-model="showBookmarksOnly" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500/20">
                        <span class="font-medium select-none"><i class="fa-solid fa-bookmark text-amber-500 mr-1"></i>Hồ sơ đã lưu ghim</span>
                    </label>
                    <button @click="resetFilters()" class="text-xs text-blue-600 hover:text-blue-800 font-semibold transition-colors flex items-center space-x-1">
                        <i class="fa-solid fa-rotate-left"></i> <span>Đặt lại bộ lọc</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- THANH ĐIỀU KHIỂN CHẾ ĐỘ XEM -->
        <div class="space-y-4">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-white border border-slate-200 rounded-2xl p-4 shadow-sm">
                <div>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest block">Dữ liệu hiển thị</span>
                    <div class="text-sm font-semibold text-slate-700 mt-0.5">
                        Tìm thấy: <span class="text-blue-600 font-extrabold" x-text="filteredDocs.length">0</span> kết quả phân loại
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-3.5">
                    <div class="flex items-center space-x-1">
                        <span class="text-xs text-slate-400">Sắp xếp:</span>
                        <button @click="toggleSort('date')" class="text-xs px-2.5 py-1.5 bg-slate-50 rounded-xl border border-slate-200 flex items-center space-x-1.5 text-slate-700 hover:bg-slate-100 transition">
                            <span>Ngày ban hành</span>
                            <i class="fa-solid text-[10px]" :class="sortField === 'date' ? (sortDirection === 'asc' ? 'fa-arrow-up' : 'fa-arrow-down') : 'fa-minus text-slate-300'"></i>
                        </button>
                        <button @click="toggleSort('hsCode')" class="text-xs px-2.5 py-1.5 bg-slate-50 rounded-xl border border-slate-200 flex items-center space-x-1.5 text-slate-700 hover:bg-slate-100 transition">
                            <span>Mã HS</span>
                            <i class="fa-solid text-[10px]" :class="sortField === 'hsCode' ? (sortDirection === 'asc' ? 'fa-arrow-up' : 'fa-arrow-down') : 'fa-minus text-slate-300'"></i>
                        </button>
                    </div>

                    <span class="h-5 w-px bg-slate-200 hidden sm:inline"></span>

                    <div class="flex items-center space-x-1" x-show="viewMode === 'table'">
                        <button @click="density = 'dense'" :class="density === 'dense' ? 'bg-blue-50 text-blue-700 border-blue-200 font-bold' : 'bg-slate-50 text-slate-500 hover:bg-slate-100 border-slate-200'" class="p-2 rounded-xl text-xs transition border" title="Mật độ chặt chẽ">
                            <i class="fa-solid fa-align-justify"></i>
                        </button>
                        <button @click="density = 'comfortable'" :class="density === 'comfortable' ? 'bg-blue-50 text-blue-700 border-blue-200 font-bold' : 'bg-slate-50 text-slate-500 hover:bg-slate-100 border-slate-200'" class="p-2 rounded-xl text-xs transition border" title="Mật độ thoáng">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                    </div>

                    <span class="h-5 w-px bg-slate-200" x-show="viewMode === 'table'"></span>

                    <div class="bg-slate-100 p-1 rounded-xl flex space-x-1">
                        <button @click="viewMode = 'card'" :class="viewMode === 'card' ? 'bg-white text-blue-600 font-bold shadow-sm' : 'text-slate-500 hover:text-slate-900'" class="px-3.5 py-1.5 rounded-lg text-xs flex items-center space-x-1.5 transition">
                            <i class="fa-solid fa-grip"></i>
                            <span>Dạng Thẻ</span>
                        </button>
                        <button @click="viewMode = 'table'" :class="viewMode === 'table' ? 'bg-white text-blue-600 font-bold shadow-sm' : 'text-slate-500 hover:text-slate-900'" class="px-3.5 py-1.5 rounded-lg text-xs flex items-center space-x-1.5 transition">
                            <i class="fa-solid fa-table-list"></i>
                            <span>Dạng Bảng</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- HÀNH ĐỘNG HÀNG LOẠT -->
            <div class="bg-blue-50 border border-blue-200 text-blue-900 rounded-2xl px-5 py-3 flex flex-col sm:flex-row items-center justify-between gap-3 shadow-sm transition-all duration-300" x-show="selectedDocs.length > 0" x-transition>
                <div class="flex items-center space-x-2">
                    <i class="fa-solid fa-circle-info text-blue-600 text-base"></i>
                    <span class="text-xs sm:text-sm font-semibold">
                        Đã chọn <span x-text="selectedDocs.length" class="underline font-extrabold text-blue-700">0</span> hồ sơ phân tích
                    </span>
                </div>
                <div class="flex items-center space-x-2 w-full sm:w-auto justify-end">
                    <button @click="bulkBookmark()" class="bg-white hover:bg-slate-100 text-slate-700 border border-slate-200 px-3 py-2 rounded-xl text-xs font-bold transition flex items-center space-x-1.5 shadow-sm">
                        <i class="fa-solid fa-bookmark text-amber-500"></i>
                        <span>Lưu ghim loạt đã chọn</span>
                    </button>
                    <button @click="bulkExcelExport()" class="bg-blue-600 hover:bg-blue-700 text-white px-3.5 py-2 rounded-xl text-xs font-bold transition flex items-center space-x-1.5 shadow-md shadow-blue-500/10">
                        <i class="fa-regular fa-file-excel"></i>
                        <span>Xuất danh mục Excel</span>
                    </button>
                    <button @click="selectedDocs = []" class="bg-transparent hover:bg-blue-100 text-blue-700 border border-transparent px-3 py-2 rounded-xl text-xs font-semibold transition">
                        Bỏ chọn tất cả
                    </button>
                </div>
            </div>

            <!-- GIAO DIỆN HIỂN THỊ -->
            <div>
                <!-- 1. CHẾ ĐỘ XEM THẺ -->
                <div x-show="viewMode === 'card'" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5" x-transition>
                    <template x-for="doc in paginatedDocs" :key="doc.id">
                        <div class="bg-white border border-slate-200 hover:border-blue-400 rounded-2xl p-5 flex flex-col justify-between space-y-4 hover:shadow-md transition-all relative group cursor-pointer"
                             @click="openModal(doc)">
                            <div class="flex items-center justify-between">
                                <div class="flex items-center space-x-2">
                                    <span class="font-mono text-xs font-extrabold text-blue-600" x-text="doc.id"></span>
                                    <span class="px-2 py-0.5 rounded-md text-[10px] font-semibold bg-slate-100 border border-slate-200 text-slate-600" x-text="doc.category"></span>
                                </div>
                                <div class="flex items-center space-x-1" @click.stop>
                                    <input type="checkbox" :value="doc.id" x-model="selectedDocs" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500/20 mr-2 h-4 w-4">
                                    <button @click="toggleBookmark(doc.id)" class="text-slate-300 hover:text-amber-500 transition-colors">
                                        <i class="fa-solid fa-bookmark text-sm" :class="isBookmarked(doc.id) ? 'text-amber-500' : 'text-slate-200 hover:text-slate-400'"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="space-y-2.5 flex-grow">
                                <h4 class="text-sm font-bold text-slate-900 line-clamp-2 group-hover:text-blue-600 transition-colors leading-snug" x-text="doc.name" :title="doc.name"></h4>
                                <p class="text-xs text-slate-500 line-clamp-4 leading-relaxed" x-text="doc.chemicalComposition"></p>
                            </div>

                            <div class="flex items-center justify-between pt-3 border-t border-slate-100">
                                <span class="bg-amber-50 border border-amber-200 text-amber-800 font-mono font-bold text-xs px-2.5 py-1 rounded-lg" x-text="'HS: ' + doc.hsCode"></span>
                                <div class="flex items-center space-x-2 text-xs text-blue-600 group-hover:text-blue-700 font-bold transition-colors">
                                    <span>Chi tiết hồ sơ</span>
                                    <i class="fa-solid fa-arrow-right text-[10px] transition-transform group-hover:translate-x-1"></i>
                                </div>
                            </div>
                        </div>
                    </template>

                    <div x-show="filteredDocs.length === 0" class="col-span-full py-16 text-center bg-white border border-slate-200 rounded-2xl">
                        <div class="flex flex-col items-center justify-center space-y-3">
                            <div class="bg-slate-50 p-4 rounded-full border border-slate-100 text-slate-400">
                                <i class="fa-solid fa-folder-open text-3xl"></i>
                            </div>
                            <h4 class="text-slate-600 font-bold text-sm">Không tìm thấy dữ liệu phù hợp</h4>
                        </div>
                    </div>
                </div>

                <!-- 2. CHẾ ĐỘ XEM BẢNG -->
                <div x-show="viewMode === 'table'" class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden" x-transition>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse table-fixed min-w-[900px]">
                            <colgroup>
                                <col class="w-12">
                                <col class="w-12">
                                <col class="w-44">
                                <col class="w-36">
                                <col class="w-auto">
                                <col class="w-36">
                                <col class="w-24">
                            </colgroup>
                            <thead>
                                <tr class="bg-slate-50 border-b border-slate-200 text-[11px] font-bold text-slate-500 uppercase tracking-wider select-none">
                                    <th class="py-3.5 px-4 text-center">
                                        <input type="checkbox" @change="toggleSelectAll($event)" :checked="isAllSelected()" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500/20 h-4 w-4">
                                    </th>
                                    <th class="py-3.5 px-2 text-center"><i class="fa-solid fa-bookmark text-slate-400"></i></th>
                                    <th class="py-3.5 px-3">Số Quyết Định</th>
                                    <th class="py-3.5 px-3">Ngày Áp Mã</th>
                                    <th class="py-3.5 px-4">Tên Hàng / Đặc Tính Kỹ Thuật</th>
                                    <th class="py-3.5 px-3 text-center">Mã Số HS</th>
                                    <th class="py-3.5 px-3 text-center">Chi Tiết</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100 text-sm">
                                <template x-for="doc in paginatedDocs" :key="doc.id">
                                    <tr class="hover:bg-slate-50/80 transition-all group cursor-pointer" 
                                        :class="[
                                            selectedDocs.includes(doc.id) ? 'bg-blue-50/30' : '',
                                            density === 'dense' ? 'py-1.5' : 'py-3.5'
                                        ]"
                                        @click="if ($event.target.type !== 'checkbox' && !$event.target.closest('button')) openModal(doc)">
                                        <td class="py-3 px-4 text-center" @click.stop>
                                            <input type="checkbox" :value="doc.id" x-model="selectedDocs" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500/20 h-4 w-4">
                                        </td>
                                        <td class="py-3 px-2 text-center" @click.stop>
                                            <button @click="toggleBookmark(doc.id)" class="text-slate-300 hover:text-amber-500 transition-colors">
                                                <i class="fa-solid fa-bookmark text-sm" :class="isBookmarked(doc.id) ? 'text-amber-500' : 'text-slate-200 hover:text-slate-400'"></i>
                                            </button>
                                        </td>
                                        <td class="py-3 px-3 font-semibold text-blue-600 group-hover:text-blue-700 transition-colors whitespace-nowrap">
                                            <span x-text="doc.id" class="font-mono text-xs sm:text-sm"></span>
                                        </td>
                                        <td class="py-3 px-3 text-slate-500 text-xs whitespace-nowrap">
                                            <span x-text="formatDate(doc.date)"></span>
                                        </td>
                                        <td class="py-3 px-4 min-w-[200px]">
                                            <div class="font-bold text-slate-800 line-clamp-1 group-hover:text-blue-950 transition-colors text-sm" x-text="doc.name"></div>
                                            <div class="text-[11px] text-slate-400 mt-1 line-clamp-1 truncate" x-text="doc.sampleDesc"></div>
                                        </td>
                                        <td class="py-3 px-3 text-center whitespace-nowrap">
                                            <span class="inline-block px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-50 text-amber-800 border border-amber-200 font-mono" x-text="doc.hsCode"></span>
                                        </td>
                                        <td class="py-3 px-3 text-center" @click.stop>
                                            <button @click="openModal(doc)" class="bg-slate-100 hover:bg-blue-600 hover:text-white text-blue-600 p-2 rounded-xl transition shadow-sm border border-slate-200 hover:border-blue-600">
                                                <i class="fa-solid fa-file-lines text-xs"></i>
                                            </button>
                                        </td>
                                    </tr>
                                </template>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- PHÂN TRANG -->
            <div class="bg-white border border-slate-200 rounded-2xl px-5 py-4 flex flex-col sm:flex-row items-center justify-between gap-4 shadow-sm" x-show="filteredDocs.length > 0">
                <div class="text-xs text-slate-500 text-center sm:text-left">
                    Hiển thị từ <span class="font-bold text-slate-700" x-text="startIndex + 1">1</span> đến <span class="font-bold text-slate-700" x-text="Math.min(endIndex, filteredDocs.length)">10</span> trong số <span class="font-extrabold text-blue-600" x-text="filteredDocs.length"></span> kết quả phân tích
                </div>
                
                <div class="flex items-center space-x-2">
                    <button @click="prevPage()" :disabled="currentPage === 1" class="px-3 py-2 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 text-xs font-semibold disabled:opacity-40 disabled:cursor-not-allowed transition flex items-center space-x-1 shadow-sm">
                        <i class="fa-solid fa-chevron-left"></i> <span>Trước</span>
                    </button>
                    
                    <div class="flex items-center space-x-1">
                        <template x-for="p in totalPages" :key="p">
                            <button @click="currentPage = p" 
                                    :class="currentPage === p ? 'bg-blue-600 text-white font-bold' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'"
                                    class="h-8 w-8 text-xs rounded-xl transition-all shadow-sm"
                                    x-text="p">
                            </button>
                        </template>
                    </div>

                    <button @click="nextPage()" :disabled="currentPage === totalPages" class="px-3 py-2 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 text-slate-700 text-xs font-semibold disabled:opacity-40 disabled:cursor-not-allowed transition flex items-center space-x-1 shadow-sm">
                        <span>Sau</span> <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <!-- MODAL CHI TIẾT -->
    <div class="fixed inset-0 z-50 overflow-y-auto" x-show="showModal" x-transition style="display: none;">
        <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm transition-opacity" @click="closeModal()"></div>

        <div class="flex items-center justify-center min-h-screen p-4 sm:p-6 lg:p-8">
