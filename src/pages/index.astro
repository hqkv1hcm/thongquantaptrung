                },

                isAllSelected() {
                    const paginatedIds = this.paginatedDocs.map(d => d.id);
                    return paginatedIds.length > 0 && paginatedIds.every(id => this.selectedDocs.includes(id));
                },

                toggleSelectAll(event) {
                    const paginatedIds = this.paginatedDocs.map(d => d.id);
                    if (event.target.checked) {
                        paginatedIds.forEach(id => {
                            if (!this.selectedDocs.includes(id)) {
                                this.selectedDocs.push(id);
                            }
                        });
                    } else {
                        this.selectedDocs = this.selectedDocs.filter(id => !paginatedIds.includes(id));
                    }
                },

                formatDate(dateStr) {
                    if (!dateStr) return "";
                    const date = new Date(dateStr);
                    return date.toLocaleDateString('vi-VN', { year: 'numeric', month: '2-digit', day: '2-digit' });
                },

                formatFullDate(dateStr) {
                    if (!dateStr) return "ngày ... tháng ... năm ...";
                    const date = new Date(dateStr);
                    return `ngày ${date.getDate()} tháng ${date.getMonth() + 1} năm ${date.getFullYear()}`;
                },

                get filteredDocs() {
                    let items = this.documents.filter(doc => {
                        if (this.activeCategory !== "Tất cả" && doc.category !== this.activeCategory) {
                            return false;
                        }

                        if (this.showBookmarksOnly && !this.bookmarks.includes(doc.id)) {
                            return false;
                        }

                        if (this.searchQuery) {
                            const query = this.searchQuery.toLowerCase();
                            const matchId = doc.id.toLowerCase().includes(query);
                            const matchName = doc.name.toLowerCase().includes(query);
                            const matchDesc = doc.sampleDesc.toLowerCase().includes(query);
                            const matchChem = doc.chemicalComposition.toLowerCase().includes(query);
                            if (!matchId && !matchName && !matchDesc && !matchChem) return false;
                        }

                        if (this.searchHs) {
                            const clearHs = this.searchHs.replace(/\./g, "");
                            const clearDocHs = doc.hsCode.replace(/\./g, "");
                            if (!clearDocHs.startsWith(clearHs)) return false;
                        }

                        if (this.filterYear) {
                            const docYear = new Date(doc.date).getFullYear().toString();
                            if (docYear !== this.filterYear) return false;
                        }

                        return true;
                    });

                    items.sort((a, b) => {
                        let fieldA = a[this.sortField];
                        let fieldB = b[this.sortField];

                        if (this.sortField === 'date') {
                            fieldA = new Date(fieldA);
                            fieldB = new Date(fieldB);
                        }

                        if (fieldA < fieldB) return this.sortDirection === 'asc' ? -1 : 1;
                        if (fieldA > fieldB) return this.sortDirection === 'asc' ? 1 : -1;
                        return 0;
                    });

                    return items;
                },

                get totalPages() {
                    return Math.max(1, Math.ceil(this.filteredDocs.length / this.pageSize));
                },

                get startIndex() {
                    return (this.currentPage - 1) * this.pageSize;
                },

                get endIndex() {
                    return this.currentPage * this.pageSize;
                },

                get paginatedDocs() {
                    return this.filteredDocs.slice(this.startIndex, this.endIndex);
                },

                prevPage() {
                    if (this.currentPage > 1) this.currentPage--;
                },

                nextPage() {
                    if (this.currentPage < this.totalPages) this.currentPage++;
                },

                openModal(doc) {
                    if (doc && doc.id) {
                        this.activeDoc = doc;
                        this.showModal = true;
                    }
                },

                closeModal() {
                    this.showModal = false;
                },

                printDocument() {
                    window.print();
                }
            }
        }
    </script>
</body>
</html>