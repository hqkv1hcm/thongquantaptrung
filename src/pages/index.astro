---
// ==========================================
// CHẶNG 1: LẤY VÀ XỬ LÝ DỮ LIỆU GOOGLE SHEETS (DẠNG JSON)
// ==========================================
const SHEET_ID = '10MHvD3yDWQVuR0oXnef9e_mo0G4U2DFfy8caKrezQ0o';
// Sử dụng URL xuất định dạng JSON từ Google Visualization API
const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:json`;

let products = [];

try {
  const response = await fetch(url);
  const text = await response.text();
  
  // Google API trả về chuỗi có bọc hàm bên ngoài: google.visualization.Query.setResponse({...});
  // Chúng ta cần cắt bỏ phần bọc này để lấy phần JSON thuần túy
  const jsonString = text.substring(text.indexOf('{'), text.lastIndexOf('}') + 1);
  const data = JSON.parse(jsonString);
  
  // Danh sách các cột theo đúng thứ tự trên Google Sheets của bạn
  const headers = [
    'id', 'date', 'name', 'declaredName', 'importer', 'hsCode', 
    'authority', 'category', 'declarationNum', 'sampleDesc', 
    'chemicalComposition', 'hsDescription'
  ];

  // Lấy dữ liệu từ các hàng (rows)
  const rows = data.table.rows;
  
  products = rows.map(row => {
    let obj = {};
    headers.forEach((header, index) => {
      // row.c[index] chứa giá trị của từng ô, .v là giá trị thuần túy, .f là giá trị đã định dạng (đối với ngày tháng)
      const cell = row.c[index];
      if (cell) {
        obj[header] = cell.f ? cell.f : (cell.v !== null ? String(cell.v) : '');
      } else {
        obj[header] = '';
      }
    });
    return obj;
  });

} catch (error) {
  console.error("Lỗi khi lấy dữ liệu từ Google Sheets: ", error);
}
---

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Tra Cứu Phân Tích Phân Loại Hàng Hóa</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        header {
            text-align: center;
            margin-bottom: 40px;
        }
        header h1 {
            color: #0B2545;
            margin-bottom: 10px;
        }
        header p {
            color: #666;
            font-size: 1.1rem;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-top: 4px solid #134074;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 1px dashed #ddd;
            padding-bottom: 10px;
        }
        .doc-id {
            background-color: #EEF4F8;
            color: #134074;
            font-weight: bold;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.9rem;
        }
        .doc-date {
            color: #888;
            font-size: 0.85rem;
        }
        .product-name {
            font-size: 1.2rem;
            color: #0B2545;
            margin: 0 0 10px 0;
            font-weight: 600;
            line-height: 1.4;
        }
        .badge-container {
            margin-bottom: 15px;
        }
        .badge-hscode {
            background-color: #EEF1E6;
            color: #588157;
            font-weight: bold;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            border: 1px solid #A3B18A;
        }
        .badge-category {
            background-color: #FDF0D5;
            color: #C1121F;
            font-weight: bold;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            margin-left: 5px;
        }
        .details {
            font-size: 0.9rem;
            color: #555;
            background-color: #fafafa;
            padding: 10px;
            border-radius: 6px;
        }
        .details p {
            margin: 5px 0;
        }
        .label {
            font-weight: bold;
            color: #666;
        }
        .no-data {
            text-align: center;
            grid-column: 1 / -1;
            padding: 40px;
            color: #888;
            background: #fff;
            border-radius: 8px;
            border: 1px dashed #ccc;
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>Hệ Thống Tra Cứu Kết Quả Phân Tích Phân Loại</h1>
            <p>Dữ liệu được cập nhật tự động theo thời gian thực từ Google Sheets</p>
        </header>

        <div class="grid">
            {products.length > 0 ? (
                products.map((product) => (
                    <div class="card">
                        <div>
                            <div class="card-header">
                                <span class="doc-id">{product.id || 'N/A'}</span>
                                <span class="doc-date">Ngày: {product.date || 'N/A'}</span>
                            </div>

                            <h3 class="product-name">{product.name || 'Chưa rõ tên'}</h3>

                            <div class="badge-container">
                                <span class="badge-hscode">Mã HS: {product.hsCode || 'N/A'}</span>
                                {product.category && <span class="badge-category">{product.category}</span>}
                            </div>

                            <div class="details">
                                {product.declaredName && <p><span class="label">Tên khai báo:</span> {product.declaredName}</p>}
                                {product.importer && <p><span class="label">Doanh nghiệp XNK:</span> {product.importer}</p>}
                                {product.declarationNum && <p><span class="label">Số tờ khai:</span> {product.declarationNum}</p>}
                                {product.authority && <p><span class="label">Cơ quan ban hành:</span> {product.authority}</p>}
                                {product.sampleDesc && <p><span class="label">Mô tả mẫu:</span> {product.sampleDesc}</p>}
                                {product.chemicalComposition && <p><span class="label">Thành phần hóa học:</span> {product.chemicalComposition}</p>}
                                {product.hsDescription && <p><span class="label">Mô tả HS:</span> {product.hsDescription}</p>}
                            </div>
                        </div>
                    </div>
                ))
            ) : (
                <div class="no-data">
                    <p>Không tìm thấy dữ liệu hoặc đang đồng bộ từ Google Sheets...</p>
                </div>
            )}
        </div>
    </div>

</body>
</html>