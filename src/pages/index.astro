// ==========================================
// CHẶNG 1: LẤY VÀ XỬ LÝ DỮ LIỆU GOOGLE SHEETS
// ==========================================
const SHEET_ID = '10MHvD3yDWQVuR0oXnef9e_mo0G4U2DFfy8caKrezQ0o';
const SHEET_NAME = '1'; 

const url = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=${SHEET_NAME}`;

const response = await fetch(url);
const csvText = await response.text();

function parseCSV(csv) {
  const lines = csv.split('\n');
  if (lines.length === 0) return [];
  
  // Lấy chính xác tên các cột: id, date, name, declaredName, importer, hsCode, authority, category, declarationNum, sampleDesc, chemicalComposition, hsDescription
  const headers = lines[0].match(/(".*?"|[^",\s]+)(?=\s*,|\s*$)/g).map(h => h.replace(/^"|"$/g, '').trim());
  
  return lines.slice(1).filter(line => line.trim() !== '').map(line => {
    const values = line.match(/(".*?"|[^",\s]+)(?=\s*,|\s*$)/g) || [];
    const cleanValues = values.map(val => val.replace(/^"|"$/g, '').replace(/""/g, '"').trim());
    
    let obj = {};
    headers.forEach((header, index) => {
      obj[header] = cleanValues[index] || '';
    });
    return obj;
  });
}

const products = parseCSV(csvText);
---

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ Thống Tra Cứu Phân Tích Phân Loại Hàng Hóa</title>
    <style>
        /* Giao diện mẫu chuyên nghiệp, hiện đại với tông màu Navy Blue & Gold */
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 20px;
            color: #333;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        header {
            text-align: center;
            margin-bottom: 40px;
        }
        header h1 {
            color: #0B2545; /* Navy Blue */
            margin-bottom: 10px;
        }
        header p {
            color: #666;
            font-size: 1.1rem;
        }
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 20px;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            border-top: 4px solid #134074;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
            border-bottom: 1px dashed #ddd;
            padding-bottom: 10px;
        }
        .doc-id {
            background-color: #EEF4F8;
            color: #134074;
            font-weight: bold;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.9rem;
        }
        .doc-date {
            color: #888;
            font-size: 0.85rem;
        }
        .product-name {
            font-size: 1.2rem;
            color: #0B2545;
            margin: 0 0 10px 0;
            font-weight: 600;
            line-height: 1.4;
        }
        .badge-container {
            margin-bottom: 15px;
        }
        .badge-hscode {
            background-color: #EEF1E6;
            color: #588157;
            font-weight: bold;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            border: 1px solid #A3B18A;
        }
        .badge-category {
            background-color: #FDF0D5;
            color: #C1121F;
            font-weight: bold;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.85rem;
            margin-left: 5px;
        }
        .details {
            font-size: 0.9rem;
            color: #555;
            background-color: #fafafa;
            padding: 10px;
            border-radius: 6px;
        }
        .details p {
            margin: 5px 0;
        }
        .label {
            font-weight: bold;
            color: #666;
        }
    </style>
</head>
<body>

    <div class="container">
        <header>
            <h1>Hệ Thống Tra Cứu Kết Quả Phân Tích Phân Loại</h1>
            <p>Dữ liệu được cập nhật tự động theo thời gian thực từ Google Sheets</p>
        </header>

        <div class="grid">
            {products.map((product) => (
                <div class="card">
                    <div>
                        <!-- 1. Số văn bản quyết định và Ngày ban hành -->
                        <div class="card-header">
                            <span class="doc-id">{product.id}</span>
                            <span class="doc-date">Ngày: {product.date}</span>
                        </div>

                        <!-- 2. Tên thương mại / Tên hàng hóa -->
                        <h3 class="product-name">{product.name}</h3>

                        <!-- 3. Mã HS Code và Phân loại danh mục -->
                        <div class="badge-container">
                            <span class="badge-hscode">Mã HS: {product.hsCode}</span>
                            {product.category && <span class="badge-category">{product.category}</span>}
                        </div>

                        <!-- 4. Chi tiết các thông tin nghiệp vụ hải quan khác từ file Sheets -->
                        <div class="details">
                            {product.declaredName && <p><span class="label">Tên khai báo:</span> {product.declaredName}</p>}
                            {product.importer && <p><span class="label">Doanh nghiệp XNK:</span> {product.importer}</p>}
                            {product.declarationNum && <p><span class="label">Số tờ khai:</span> {product.declarationNum}</p>}
                            {product.authority && <p><span class="label">Cơ quan ban hành:</span> {product.authority}</p>}
                            {product.sampleDesc && <p><span class="label">Mô tả mẫu:</span> {product.sampleDesc}</p>}
                            {product.chemicalComposition && <p><span class="label">Thành phần hóa học:</span> {product.chemicalComposition}</p>}
                            {product.hsDescription && <p><span class="label">Mô tả HS:</span> {product.hsDescription}</p>}
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>

</body>
</html>